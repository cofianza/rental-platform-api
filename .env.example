# ============================================================
# Habitar Propiedades 2.0 - Backend API
# Variables de entorno requeridas
# Copiar a .env.local y completar con valores reales
# ============================================================

# --- Aplicacion ---
NODE_ENV=development
PORT=4000

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# --- CORS ---
CORS_ORIGIN=http://localhost:3000

# --- Logging ---
# Valores: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# --- Proveedores de riesgo crediticio ---
# Usar mock provider para desarrollo (true/false)
CREDIT_PROVIDER_USE_MOCK=true
# TransUnion
TRANSUNION_API_URL=
TRANSUNION_API_KEY=
# SIFIN
SIFIN_API_URL=
SIFIN_API_KEY=
# DataCredito
DATACREDITO_API_URL=
DATACREDITO_API_KEY=
